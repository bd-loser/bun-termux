#!/data/data/com.termux/files/usr/bin/bash
# postinst — runs after `dpkg -i bun_*.deb` on Termux
# This is invoked by dpkg as the install user (u0_aXXX), not as root.

set -e

PREFIX="${PREFIX:-/data/data/com.termux/files/usr}"
FIX_SCRIPT="$PREFIX/bin/bun-fix-network"

echo ""
echo "┌─────────────────────────────────────────────────────────────┐"
echo "│  Bun for Termux installed                                    │"
echo "└─────────────────────────────────────────────────────────────┘"
echo ""
echo "  Version : $(bun --version 2>/dev/null || echo 'unknown')"
echo "  Binary  : $PREFIX/lib/bun-termux/bun"
echo "  Launcher: $PREFIX/bin/bun"
echo ""

# Detect whether /etc/resolv.conf exists. If not, Bun's c-ares resolver
# will fall back to 8.8.8.8 — which is blocked on many APAC carriers.
# This is a heuristic; bun-fix-network will do the real test.
NEEDS_FIX=0
if [ ! -f /etc/resolv.conf ]; then
    NEEDS_FIX=1
fi

# Quick connectivity test using curl (which uses Android's resolver)
if ! curl -sI --max-time 5 https://registry.npmjs.org/@types/bun >/dev/null 2>&1; then
    NEEDS_FIX=1
fi

if [ "$NEEDS_FIX" = "1" ]; then
    echo "  ⚠  Your network may block Bun's DNS resolver."
    echo "     If 'bun install' fails with 'ConnectionRefused', run:"
    echo ""
    echo "         bun-fix-network"
    echo ""
    echo "     This sets up a local tinyproxy + HTTPS_PROXY automatically."
    echo ""
else
    echo "  ✓  Network looks healthy. Try: bun install"
    echo ""
fi

echo "  Useful commands:"
echo "    bun --version"
echo "    bunx prettier --version   (bunx is now installed!)"
echo "    bun-fix-network    (auto-fix network issues if they appear)"
echo ""

# Verify bunx launcher is installed (the missing piece that caused
# CouldntReadCurrentDirectory for users with unpatched ~/.bun/bin/bunx)
if [ -x "$PREFIX/bin/bunx" ]; then
    echo "  [OK] bunx launcher installed at $PREFIX/bin/bunx"
else
    echo "  [WARN] bunx launcher NOT found at $PREFIX/bin/bunx"
    echo "         Report this — the package should have installed it."
fi
echo ""

# Warn if an unpatched bunx exists earlier in PATH (e.g. from
# `curl https://bun.sh/install | bash`, which installs to ~/.bun/bin/bunx).
# That unpatched bunx does NOT have the resolver/run_command patches and
# will fail with CouldntReadCurrentDirectory. The fix is to either remove
# ~/.bun/bin/bunx or ensure $PREFIX/bin comes first in PATH.
CONFLICTING_BUNX=""
IFS=':' read -ra PATH_DIRS <<< "${PATH:-}"
for dir in "${PATH_DIRS[@]}"; do
    if [ "$dir" = "$PREFIX/bin" ]; then
        break  # $PREFIX/bin comes first — no conflict possible
    fi
    if [ -x "$dir/bunx" ] && [ "$dir" != "$PREFIX/bin" ]; then
        CONFLICTING_BUNX="$dir/bunx"
        break
    fi
done
if [ -n "$CONFLICTING_BUNX" ]; then
    echo "  [!] WARNING: An unpatched bunx was found earlier in PATH:"
    echo "        $CONFLICTING_BUNX"
    echo "      This will shadow the patched $PREFIX/bin/bunx and cause"
    echo "      'CouldntReadCurrentDirectory' errors."
    echo ""
    echo "      Fix options:"
    echo "        1. Remove it:  rm $CONFLICTING_BUNX"
    echo "        2. Reorder PATH so $PREFIX/bin comes first."
    echo ""
fi

exit 0
